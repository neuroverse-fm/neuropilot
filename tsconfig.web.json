{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "WebWorker"
    ],
    "outDir": "./out/web" // ESBuild will bundle anyway
  },
  "include": [
    "src/web/**/*",
    "src/**/*"
  ],
  "exclude": [
    "src/desktop/**/*",
    "src/test/**/*"
  ]
}